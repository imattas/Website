---
import TextmodeLayout from "../../../../layouts/textmode/TextmodeLayout.astro";
import PhileShell from "../../../../components/phile/PhileShell.astro";
import { getAllPhiles } from "../../../../modules/philes/repository";
import { phileExcerpt } from "../../../../modules/seo/xml";

export async function getStaticPaths() {
  const philes = await getAllPhiles();
  return philes.map((phile) => ({
    params: {
      volume: String(phile.route.volume),
      slug: phile.route.slug
    }
  }));
}

const volumeNumber = Number(Astro.params.volume);
const allPhiles = await getAllPhiles();
const phile = allPhiles.find(
  (candidate) => candidate.route.volume === volumeNumber && candidate.route.slug === (Astro.params.slug ?? "")
);

if (!phile) {
  return Astro.redirect("/");
}

const childPhiles =
  phile.data.writeupKind === "ctf"
    ? allPhiles.filter(
        (candidate) =>
          candidate.route.volume === volumeNumber &&
          candidate.data.writeupKind === "challenge" &&
          candidate.data.ctfSlug === phile.data.ctfSlug
      )
    : [];
const hasCjk = phile.data.lang === "zh" || /[\p{Script=Han}]/u.test(`${phile.data.title}\n${phile.body}`);
---

<TextmodeLayout
  title={phile.data.title}
  description={phileExcerpt(phile)}
  preloadCjk={hasCjk}
  pageType="article"
  publishedTime={phile.data.date}
>
  <PhileShell phile={phile} childPhiles={childPhiles} />
</TextmodeLayout>
