---
import Analytics from "@vercel/analytics/astro";
import stylesheetUrl from "../../styles/global.css?url";
import { appearanceConfig, effectsConfig, siteConfig, textmodeConfig } from "../../config";
import { appearanceCssVariables } from "../../modules/textmode/core/css-vars";
import { siteHref } from "../../modules/textmode/core/html";

type Props = {
  title?: string;
  tabTitle?: string;
  description?: string;
  preloadCjk?: boolean;
  pageType?: "website" | "article";
  publishedTime?: Date;
};

const pageTitle = Astro.props.title ? `${Astro.props.title} :: ${siteConfig.name}` : siteConfig.name;
const tabTitle = Astro.props.tabTitle ?? siteConfig.name;
const description = Astro.props.description ?? siteConfig.description;
const preloadCjk = Astro.props.preloadCjk ?? false;
const pageType = Astro.props.pageType ?? "website";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const rssUrl = new URL(siteHref("/rss.xml"), Astro.site ?? Astro.url).toString();
const appearanceCss = appearanceCssVariables(appearanceConfig);
const mobileFitBreakpoint = textmodeConfig.mobileFitBreakpoint;
const particlesEnabled = effectsConfig.particles.enable;
const asciiFontUrl = siteHref(appearanceConfig.fonts.asciiUrl);
const cjkBodyAtlas = siteHref("/assets/cjk/wqy-cjk-body.png");
const cjkLinkAtlas = siteHref("/assets/cjk/wqy-cjk-link.png");
const analyticsEnabled = import.meta.env.VERCEL === "1";
const seoKeywords = [
  "Ian Mattas",
  "imattas",
  "red team",
  "cybersecurity",
  "CTF",
  "pwn",
  "security tooling",
  "portfolio"
];
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ian Mattas",
  alternateName: "imattas",
  url: new URL(siteHref("/"), Astro.site ?? Astro.url).toString(),
  sameAs: [
    "https://github.com/imattas",
    "https://linkedin.com/in/ian-mattas",
    "https://github.com/redsecc",
    "https://idktheflag.sh"
  ],
  jobTitle: "Aspiring red teamer",
  description
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Ian Mattas" />
    <meta name="keywords" content={seoKeywords.join(", ")} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#05070a" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={rssUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@imattas" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {
      Astro.props.publishedTime && (
        <meta property="article:published_time" content={Astro.props.publishedTime.toISOString()} />
      )
    }
    <link rel="stylesheet" href={stylesheetUrl} />
    <script is:inline type="application/ld+json" set:html={jsonLd}></script>
    <style set:html={appearanceCss}></style>
    <link
      rel="preload"
      href={asciiFontUrl}
      as="font"
      type={`font/${appearanceConfig.fonts.asciiFormat}`}
      crossorigin
    />
    {preloadCjk && <link rel="preload" href={cjkBodyAtlas} as="image" />}
    {preloadCjk && <link rel="preload" href={cjkLinkAtlas} as="image" />}
    <title>{tabTitle}</title>
  </head>
  <body data-mobile-fit-breakpoint={mobileFitBreakpoint} data-particles-enabled={particlesEnabled}>
    <slot />
    {analyticsEnabled && <Analytics />}
    <script>
      import { installTextmodeBootstrap } from "../../modules/textmode/bootstrap/install";

      installTextmodeBootstrap();
    </script>
  </body>
</html>
