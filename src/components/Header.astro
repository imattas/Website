---
const base = import.meta.env.BASE_URL;
---
<header>
    <nav>
        <h2>
            <a href={base} class="brand-link">
                <img src={`${base}/logo.svg`} alt="Zemi logo" class="nav-logo" />
                Zemi
            </a>
        </h2>
        <div class="internal-links">
            <a href={base}>Home</a>
            <a href={`${base}/blog`}>Challenges</a>
            <a href={`${base}/docs`}>Docs</a>
            <a href={`${base}/about`}>About</a>
        </div>
        <div class="social-links">
            <a href="https://github.com/ian" target="_blank" title="GitHub">
                <span class="sr-only">GitHub</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28">
                    <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
                </svg>
            </a>
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 0 1.5em;
        background: var(--bg-color);
        border-bottom: 2px solid var(--accent);
    }
    
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Flex: 1 forces the left and right sides to take equal space, perfectly centering the middle */
    h2 {
        margin: 0;
        font-size: 1.2em;
        flex: 1; 
        display: flex;
        justify-content: flex-start;
    }

    .internal-links {
        display: flex;
        gap: 1.5em;
        justify-content: center;
    }

    nav a {
        color: var(--text-heading);
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    nav a:hover {
        color: var(--accent);
    }

    .brand-link {
        display: flex;
        align-items: center;
        gap: 0.5em;
    }

    .nav-logo {
        height: 1.5em;
        width: auto;
        image-rendering: pixelated; /* Preserves the MS Paint glory */
    }

    .social-links {
        flex: 1; 
        display: flex;
        justify-content: flex-end;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    @media (max-width: 720px) {
        .social-links { display: none; }
        h2 { flex: none; }
    }
</style>
